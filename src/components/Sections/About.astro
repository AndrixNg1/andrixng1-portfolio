---
import { User, Code2, Server, Smartphone, Database, Cloud, Zap } from 'lucide-astro';
import Card from '../ui/Card.astro';
import SectionHeader from '../ui/SectionHeader.astro';
---

<Card>
  <SectionHeader title="About Me">
    <User slot="icon" class="w-5 h-5" />
  </SectionHeader>

  <div class="flex flex-col gap-6 text-text-secondary leading-relaxed text-lg">
    <p>
      I'm <strong class="text-text-primary font-bold">Andrix Ngoyi</strong>, a passionate Software Engineer with a deep focus on crafting premium digital experiences. I specialize in building highly interactive, scalable, and beautifully designed web applications.
    </p>
    <p>
      My approach bridges the gap between complex engineering and elegant design. By leveraging modern technologies like <span class="text-accent-green font-medium">Astro</span>, <span class="text-accent-green font-medium">Next.js</span>, and fluid animations via <span class="text-accent-orange font-medium">GSAP</span>, I transform concepts into award-winning digital products.
    </p>
    <p>
      Whether it's architecting a robust backend or refining a glassmorphic user interface, my goal is always the same: <span class="text-text-primary italic">deliver exceptional quality that drives business success.</span>
    </p>
  </div>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-10">
    <div class="flex flex-col gap-2 p-4 bg-bg-secondary rounded-2xl border border-border text-center">
      <span class="text-3xl font-bold text-accent-green">3+</span>
      <span class="text-sm font-medium text-text-muted">Years Experience</span>
    </div>
    <div class="flex flex-col gap-2 p-4 bg-bg-secondary rounded-2xl border border-border text-center">
      <span class="text-3xl font-bold text-accent-orange">20+</span>
      <span class="text-sm font-medium text-text-muted">Projects Completed</span>
    </div>
    <div class="flex flex-col gap-2 p-4 bg-bg-secondary rounded-2xl border border-border text-center">
      <span class="text-3xl font-bold text-accent-green">15+</span>
      <span class="text-sm font-medium text-text-muted">Happy Clients</span>
    </div>
    <div class="flex flex-col gap-2 p-4 bg-bg-secondary rounded-2xl border border-border text-center">
      <span class="text-3xl font-bold text-accent-orange">24/7</span>
      <span class="text-sm font-medium text-text-muted">Support</span>
    </div>
  </div>
</Card>
