---
import { Mail, Send, MessageSquare, Linkedin, Github } from 'lucide-astro';
import Card from '../ui/Card.astro';
import SectionHeader from '../ui/SectionHeader.astro';
import Button from '../ui/Button.astro';
---

<Card className="relative overflow-hidden">
  <!-- Decorative background elements -->
  <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 w-64 h-64 bg-accent-green/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/3 w-64 h-64 bg-accent-orange/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative z-10">
    <SectionHeader title="Let's Work Together">
      <MessageSquare slot="icon" class="w-5 h-5" />
    </SectionHeader>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
      <!-- Contact Info -->
      <div class="flex flex-col gap-6">
        <p class="text-text-secondary text-lg leading-relaxed">
          I'm currently available for freelance projects and full-time opportunities. 
          If you're looking to build something extraordinary, feel free to reach out.
        </p>

        <div class="flex flex-col gap-4 mt-4">
          <a href="mailto:andrixngoyi243@gmail.com" class="flex items-center gap-4 p-4 bg-bg-secondary border border-border rounded-xl hover:border-accent-green transition-colors group">
            <div class="w-10 h-10 bg-accent-green/10 rounded-lg flex items-center justify-center text-accent-green group-hover:scale-110 transition-transform">
              <Mail class="w-5 h-5" />
            </div>
            <div>
              <p class="text-sm text-text-muted font-medium mb-0.5">Email Me</p>
              <p class="font-semibold">andrixngoyi243@gmail.com</p>
            </div>
          </a>

          <a href="#" class="flex items-center gap-4 p-4 bg-bg-secondary border border-border rounded-xl hover:border-accent-orange transition-colors group">
            <div class="w-10 h-10 bg-accent-orange/10 rounded-lg flex items-center justify-center text-accent-orange group-hover:scale-110 transition-transform">
              <Linkedin class="w-5 h-5" />
            </div>
            <div>
              <p class="text-sm text-text-muted font-medium mb-0.5">Connect on LinkedIn</p>
              <p class="font-semibold">Andrix Ngoyi</p>
            </div>
          </a>
        </div>
      </div>

      <!-- Contact Form -->
      <form class="flex flex-col gap-5 p-6 bg-bg-secondary/50 border border-border rounded-2xl backdrop-blur-sm">
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
          <div class="flex flex-col gap-2">
            <label for="name" class="text-sm font-medium text-text-secondary">Your Name</label>
            <input type="text" id="name" placeholder="John Doe" class="w-full bg-bg-primary border border-border rounded-xl px-4 py-3 focus:outline-none focus:border-accent-green focus:ring-1 focus:ring-accent-green transition-colors text-text-primary placeholder:text-text-muted" required />
          </div>
          <div class="flex flex-col gap-2">
            <label for="email" class="text-sm font-medium text-text-secondary">Your Email</label>
            <input type="email" id="email" placeholder="john@example.com" class="w-full bg-bg-primary border border-border rounded-xl px-4 py-3 focus:outline-none focus:border-accent-green focus:ring-1 focus:ring-accent-green transition-colors text-text-primary placeholder:text-text-muted" required />
          </div>
        </div>
        
        <div class="flex flex-col gap-2">
          <label for="subject" class="text-sm font-medium text-text-secondary">Subject</label>
          <input type="text" id="subject" placeholder="Project Inquiry" class="w-full bg-bg-primary border border-border rounded-xl px-4 py-3 focus:outline-none focus:border-accent-green focus:ring-1 focus:ring-accent-green transition-colors text-text-primary placeholder:text-text-muted" required />
        </div>

        <div class="flex flex-col gap-2">
          <label for="message" class="text-sm font-medium text-text-secondary">Message</label>
          <textarea id="message" rows="4" placeholder="Tell me about your project..." class="w-full bg-bg-primary border border-border rounded-xl px-4 py-3 focus:outline-none focus:border-accent-green focus:ring-1 focus:ring-accent-green transition-colors text-text-primary placeholder:text-text-muted resize-none" required></textarea>
        </div>

        <Button type="submit" className="w-full mt-2">
          Send Message <Send class="w-4 h-4" />
        </Button>
      </form>
    </div>
  </div>
</Card>
