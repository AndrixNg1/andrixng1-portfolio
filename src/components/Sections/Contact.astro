---
import { MessageSquare, Mail, Linkedin, Github, Instagram, Phone } from 'lucide-astro';
import Card from '../ui/Card.astro';
import SectionHeader from '../ui/SectionHeader.astro';
---

<Card className="relative overflow-hidden">
  
  <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 w-64 h-64 bg-accent-green/10 rounded-full blur-3xl pointer-events-none"></div>
  <div class="absolute bottom-0 left-0 translate-y-1/3 -translate-x-1/3 w-64 h-64 bg-accent-orange/10 rounded-full blur-3xl pointer-events-none"></div>

  <div class="relative z-10">
    <SectionHeader title="Get In Touch">
      <MessageSquare slot="icon" class="w-5 h-5" />
    </SectionHeader>

    <p class="text-text-secondary text-lg leading-relaxed mb-8 max-w-2xl">
      I'm currently available for freelance projects and full-time opportunities. 
      If you're looking to build something extraordinary, feel free to reach out through any of the platforms below.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      
      <a href="mailto:andrixngoyi243@gmail.com" class="flex items-center gap-4 p-5 bg-bg-secondary border border-border rounded-2xl hover:border-accent-green transition-all duration-300 group">
        <div class="w-12 h-12 bg-accent-green/10 rounded-xl flex items-center justify-center text-accent-green group-hover:scale-110 transition-transform shrink-0">
          <Mail class="w-6 h-6" />
        </div>
        <div class="min-w-0">
          <p class="text-xs text-text-muted font-medium mb-0.5">Email</p>
          <p class="font-semibold truncate">andrixngoyi243@gmail.com</p>
        </div>
      </a>

      
      <a href="https://wa.me/243836066402" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 p-5 bg-bg-secondary border border-border rounded-2xl hover:border-green-500 transition-all duration-300 group">
        <div class="w-12 h-12 bg-green-500/10 rounded-xl flex items-center justify-center text-green-500 group-hover:scale-110 transition-transform shrink-0">
          <Phone class="w-6 h-6" />
        </div>
        <div class="min-w-0">
          <p class="text-xs text-text-muted font-medium mb-0.5">WhatsApp</p>
          <p class="font-semibold">+243 836 066 402</p>
        </div>
      </a>

      
      <a href="https://www.linkedin.com/in/andrix-ngoyi-469662321/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 p-5 bg-bg-secondary border border-border rounded-2xl hover:border-blue-500 transition-all duration-300 group">
        <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center text-blue-500 group-hover:scale-110 transition-transform shrink-0">
          <Linkedin class="w-6 h-6" />
        </div>
        <div class="min-w-0">
          <p class="text-xs text-text-muted font-medium mb-0.5">LinkedIn</p>
          <p class="font-semibold">Andrix Ngoyi</p>
        </div>
      </a>

      
      <a href="https://github.com/AndrixNg1" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 p-5 bg-bg-secondary border border-border rounded-2xl hover:border-text-primary transition-all duration-300 group">
        <div class="w-12 h-12 bg-bg-tertiary rounded-xl flex items-center justify-center text-text-primary group-hover:scale-110 transition-transform shrink-0">
          <Github class="w-6 h-6" />
        </div>
        <div class="min-w-0">
          <p class="text-xs text-text-muted font-medium mb-0.5">GitHub</p>
          <p class="font-semibold">AndrixNg1</p>
        </div>
      </a>

      
      <a href="https://x.com/andr6102" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 p-5 bg-bg-secondary border border-border rounded-2xl hover:border-text-primary transition-all duration-300 group">
        <div class="w-12 h-12 bg-bg-tertiary rounded-xl flex items-center justify-center text-text-primary group-hover:scale-110 transition-transform shrink-0">
          <svg class="w-6 h-6" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
        </div>
        <div class="min-w-0">
          <p class="text-xs text-text-muted font-medium mb-0.5">X (Twitter)</p>
          <p class="font-semibold">@andr6102</p>
        </div>
      </a>

      
      <a href="#" target="_blank" rel="noopener noreferrer" class="flex items-center gap-4 p-5 bg-bg-secondary border border-border rounded-2xl hover:border-pink-500 transition-all duration-300 group">
        <div class="w-12 h-12 bg-pink-500/10 rounded-xl flex items-center justify-center text-pink-500 group-hover:scale-110 transition-transform shrink-0">
          <Instagram class="w-6 h-6" />
        </div>
        <div class="min-w-0">
          <p class="text-xs text-text-muted font-medium mb-0.5">Instagram</p>
          <p class="font-semibold">andrix_ngoyi</p>
        </div>
      </a>
    </div>
  </div>
</Card>
