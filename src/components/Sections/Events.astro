---
import { CalendarDays, MapPin } from 'lucide-astro';

const events = [
  { title: "Tech Conference 2025", role: "Speaker", location: "Kinshasa", date: "Oct 2025" },
  { title: "Developer Workshop", role: "Mentor", location: "Lubumbashi", date: "Aug 2025" },
  { title: "Hackathon Finals", role: "Judge", location: "Online", date: "May 2025" }
];
---

<section id="events" class="bg-bg-primary border border-border rounded-3xl p-6 md:p-10 shadow-[var(--card-shadow)] relative overflow-hidden">
  <div class="flex items-center gap-3 mb-8">
    <CalendarDays class="w-6 h-6 text-accent-purple" />
    <h2 class="text-2xl font-bold">Events & Activities</h2>
  </div>

  <div class="flex flex-col gap-4">
    {events.map((event) => (
      <div class="group flex flex-col md:flex-row md:items-center justify-between p-6 rounded-2xl bg-bg-secondary border border-border hover:border-accent-purple/50 transition-colors duration-300 relative overflow-hidden">
        <div class="absolute left-0 top-0 bottom-0 w-1 bg-accent-purple transform scale-y-0 group-hover:scale-y-100 transition-transform duration-300 origin-top"></div>
        
        <div class="flex flex-col md:flex-row md:items-center gap-4 md:gap-8 mb-4 md:mb-0 relative z-10">
          <div class="flex flex-col">
            <h3 class="text-lg font-bold group-hover:text-accent-purple transition-colors">{event.title}</h3>
            <span class="text-sm text-text-secondary">{event.role}</span>
          </div>
        </div>

        <div class="flex items-center gap-6 text-sm text-text-muted relative z-10">
          <div class="flex items-center gap-2">
            <MapPin class="w-4 h-4" /> {event.location}
          </div>
          <div class="flex items-center gap-2">
            <CalendarDays class="w-4 h-4" /> {event.date}
          </div>
        </div>
      </div>
    ))}
  </div>
</section>
