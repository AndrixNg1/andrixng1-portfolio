---
import { CalendarDays, MapPin } from 'lucide-astro';
import Card from '../ui/Card.astro';
import SectionHeader from '../ui/SectionHeader.astro';

const events = [
  {
    title: 'Tech Summit 2026',
    role: 'Speaker',
    date: 'March 15, 2026',
    location: 'Lubumbashi, DRC',
    image: '/images/even/11bf5df6-bd93-4743-a0d6-5aa441ea8a37.jpeg'
  },
  {
    title: 'Hackathon Workshop',
    role: 'Mentor',
    date: 'February 20, 2026',
    location: 'Remote',
    image: '/images/even/3fbc3b2f-6546-4c87-b403-6be5165bd030.jpeg'
  },
  {
    title: 'Developer Meetup',
    role: 'Organizer',
    date: 'January 10, 2026',
    location: 'Kinshasa, DRC',
    image: '/images/even/b6b97381-8d63-47b7-a4d9-e4de1834ba18.jpeg'
  }
];
---

<Card>
  <SectionHeader title="Events & Talks">
    <CalendarDays slot="icon" class="w-5 h-5" />
  </SectionHeader>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    {events.map((event) => (
      <div class="group bg-bg-secondary border border-border rounded-2xl overflow-hidden hover:border-accent-green transition-all duration-300">
        <div class="relative h-40 overflow-hidden bg-bg-tertiary">
          <div class="absolute inset-0 bg-accent-green/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10"></div>
          <img 
            src={event.image} 
            alt={event.title}
            class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
          />
        </div>
        <div class="p-5">
          <div class="flex items-center justify-between mb-2">
            <span class="px-2 py-1 bg-accent-green/10 text-accent-green text-xs font-semibold rounded-md">
              {event.role}
            </span>
            <span class="text-xs text-text-muted">{event.date}</span>
          </div>
          <h3 class="font-bold text-lg mb-2 group-hover:text-accent-green transition-colors">{event.title}</h3>
          <p class="text-sm text-text-secondary flex items-center gap-1">
            <MapPin class="w-3.5 h-3.5" /> {event.location}
          </p>
        </div>
      </div>
    ))}
  </div>
</Card>
