---
import { Layers } from 'lucide-astro';

const skills = [
  { name: 'HTML5', symbol: 'H5', color: 'text-orange-500', bg: 'bg-orange-500/10', border: 'border-orange-500/20' },
  { name: 'CSS3', symbol: 'C3', color: 'text-blue-500', bg: 'bg-blue-500/10', border: 'border-blue-500/20' },
  { name: 'JavaScript', symbol: 'JS', color: 'text-yellow-400', bg: 'bg-yellow-400/10', border: 'border-yellow-400/20' },
  { name: 'TypeScript', symbol: 'TS', color: 'text-blue-600', bg: 'bg-blue-600/10', border: 'border-blue-600/20' },
  { name: 'React', symbol: 'Re', color: 'text-cyan-400', bg: 'bg-cyan-400/10', border: 'border-cyan-400/20' },
  { name: 'Astro', symbol: 'As', color: 'text-purple-500', bg: 'bg-purple-500/10', border: 'border-purple-500/20' },
  { name: 'Vue.js', symbol: 'Vu', color: 'text-emerald-500', bg: 'bg-emerald-500/10', border: 'border-emerald-500/20' },
  { name: 'TailwindCSS', symbol: 'TW', color: 'text-teal-400', bg: 'bg-teal-400/10', border: 'border-teal-400/20' },
  { name: 'Sass', symbol: 'Sa', color: 'text-pink-500', bg: 'bg-pink-500/10', border: 'border-pink-500/20' },
  
  { name: 'PHP', symbol: 'PH', color: 'text-indigo-400', bg: 'bg-indigo-400/10', border: 'border-indigo-400/20' },
  { name: 'Laravel', symbol: 'La', color: 'text-red-500', bg: 'bg-red-500/10', border: 'border-red-500/20' },
  { name: 'Node.js', symbol: 'No', color: 'text-green-500', bg: 'bg-green-500/10', border: 'border-green-500/20' },
  { name: 'Express.js', symbol: 'Ex', color: 'text-gray-400', bg: 'bg-gray-400/10', border: 'border-gray-400/20' },
  { name: 'NestJS', symbol: 'Ne', color: 'text-red-600', bg: 'bg-red-600/10', border: 'border-red-600/20' },
  
  { name: 'Flutter', symbol: 'Fl', color: 'text-cyan-500', bg: 'bg-cyan-500/10', border: 'border-cyan-500/20' },
  { name: 'Dart', symbol: 'Da', color: 'text-blue-400', bg: 'bg-blue-400/10', border: 'border-blue-400/20' },
  
  { name: 'MySQL', symbol: 'My', color: 'text-blue-600', bg: 'bg-blue-600/10', border: 'border-blue-600/20' },
  { name: 'PostgreSQL', symbol: 'Pg', color: 'text-indigo-500', bg: 'bg-indigo-500/10', border: 'border-indigo-500/20' },
  { name: 'MongoDB', symbol: 'Mo', color: 'text-green-500', bg: 'bg-green-500/10', border: 'border-green-500/20' },
  { name: 'Redis', symbol: 'Re', color: 'text-red-500', bg: 'bg-red-500/10', border: 'border-red-500/20' },
  
  { name: 'Docker', symbol: 'Do', color: 'text-blue-500', bg: 'bg-blue-500/10', border: 'border-blue-500/20' },
  { name: 'Kubernetes', symbol: 'Ku', color: 'text-blue-600', bg: 'bg-blue-600/10', border: 'border-blue-600/20' },
  { name: 'AWS', symbol: 'AW', color: 'text-orange-400', bg: 'bg-orange-400/10', border: 'border-orange-400/20' },
  { name: 'Firebase', symbol: 'Fi', color: 'text-yellow-500', bg: 'bg-yellow-500/10', border: 'border-yellow-500/20' },
  { name: 'Cloudflare', symbol: 'Cf', color: 'text-orange-500', bg: 'bg-orange-500/10', border: 'border-orange-500/20' },
  { name: 'Linux', symbol: 'Li', color: 'text-yellow-200', bg: 'bg-yellow-200/10', border: 'border-yellow-200/20' },
  { name: 'Nginx', symbol: 'Ng', color: 'text-green-600', bg: 'bg-green-600/10', border: 'border-green-600/20' },
  { name: 'CI/CD', symbol: 'CI', color: 'text-purple-400', bg: 'bg-purple-400/10', border: 'border-purple-400/20' },
  
  { name: 'Git', symbol: 'Gi', color: 'text-orange-600', bg: 'bg-orange-600/10', border: 'border-orange-600/20' },
  { name: 'GitHub', symbol: 'GH', color: 'text-gray-300', bg: 'bg-gray-300/10', border: 'border-gray-300/20' },
  { name: 'VS Code', symbol: 'VS', color: 'text-blue-500', bg: 'bg-blue-500/10', border: 'border-blue-500/20' },
  { name: 'Postman', symbol: 'Po', color: 'text-orange-500', bg: 'bg-orange-500/10', border: 'border-orange-500/20' },
  { name: 'Figma', symbol: 'Fi', color: 'text-pink-500', bg: 'bg-pink-500/10', border: 'border-pink-500/20' },
  { name: 'ESLint', symbol: 'ES', color: 'text-purple-500', bg: 'bg-purple-500/10', border: 'border-purple-500/20' },
  { name: 'Jest', symbol: 'Je', color: 'text-red-400', bg: 'bg-red-400/10', border: 'border-red-400/20' }
];
---

<section id="skills" class="bg-bg-primary border border-border rounded-3xl p-6 md:p-10 shadow-[var(--card-shadow)] relative">
  <div class="flex items-center gap-3 mb-8">
    <Layers class="w-6 h-6 text-accent-blue" />
    <h2 class="text-2xl font-bold">Tech Stack & Skills</h2>
  </div>

  <div class="grid grid-cols-2 sm:grid-cols-3 md:grid-cols-4 lg:grid-cols-6 gap-4">
    {skills.map((skill) => (
      <div class="flex flex-col items-center justify-center p-4 rounded-2xl bg-bg-secondary border border-border hover:border-accent-blue/50 hover:bg-bg-tertiary transition-all duration-300 group cursor-default">
        <div class={`w-12 h-12 rounded-xl flex items-center justify-center text-xl font-bold mb-3 ${skill.bg} ${skill.color} ${skill.border} border group-hover:scale-110 transition-transform duration-300`}>
          {skill.symbol}
        </div>
        <span class="text-xs font-medium text-text-secondary group-hover:text-text-primary transition-colors">
          {skill.name}
        </span>
      </div>
    ))}
  </div>
</section>
