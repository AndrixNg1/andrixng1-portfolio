---
import { Layers } from 'lucide-astro';
import Card from '../ui/Card.astro';
import SectionHeader from '../ui/SectionHeader.astro';

const skillCategories = [
  {
    title: 'Frontend',
    skills: [
      { name: 'React', icon: 'devicon-react-original colored' },
      { name: 'Next.js', icon: 'devicon-nextjs-plain dark:text-white' },
      { name: 'Astro', icon: 'devicon-astro-plain colored' },
      { name: 'Tailwind CSS', icon: 'devicon-tailwindcss-original colored' },
      { name: 'GSAP', icon: 'devicon-gsap-plain colored' },
      { name: 'TypeScript', icon: 'devicon-typescript-plain colored' }
    ]
  },
  {
    title: 'Backend',
    skills: [
      { name: 'Node.js', icon: 'devicon-nodejs-plain-wordmark colored' },
      { name: 'Express', icon: 'devicon-express-original dark:text-white' },
      { name: 'Python', icon: 'devicon-python-plain colored' },
      { name: 'PostgreSQL', icon: 'devicon-postgresql-plain colored' },
      { name: 'MongoDB', icon: 'devicon-mongodb-plain colored' }
    ]
  },
  {
    title: 'Tools & DevOps',
    skills: [
      { name: 'Git', icon: 'devicon-git-plain colored' },
      { name: 'Docker', icon: 'devicon-docker-plain colored' },
      { name: 'Figma', icon: 'devicon-figma-plain colored' },
      { name: 'Vercel', icon: 'devicon-vercel-original dark:text-white' },
      { name: 'AWS', icon: 'devicon-amazonwebservices-plain-wordmark colored' }
    ]
  }
];
---

<Card>
  <SectionHeader title="Tech Stack">
    <Layers slot="icon" class="w-5 h-5" />
  </SectionHeader>

  <div class="space-y-8">
    {skillCategories.map((category) => (
      <div>
        <h3 class="text-lg font-semibold mb-4 text-text-secondary">{category.title}</h3>
        <div class="flex flex-wrap gap-3">
          {category.skills.map((skill) => (
            <div class="group relative flex items-center gap-2 px-4 py-2 bg-bg-secondary border border-border rounded-lg hover:border-accent-green hover:bg-bg-tertiary transition-all duration-300">
              <i class={`${skill.icon} text-xl group-hover:scale-110 transition-transform`}></i>
              <span class="text-sm font-medium">{skill.name}</span>
            </div>
          ))}
        </div>
      </div>
    ))}
  </div>
</Card>
