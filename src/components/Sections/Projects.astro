---
import { FolderGit2, Github, ExternalLink } from 'lucide-astro';
import Card from '../ui/Card.astro';
import SectionHeader from '../ui/SectionHeader.astro';

const projects = [
  {
    title: 'GRK Prosperity',
    description: 'Premium SaaS landing page with dark mode, animations, and high-end aesthetics for a business consulting firm.',
    image: '/images/gallery-project/grk.png',
    tags: ['Astro', 'Tailwind', 'GSAP'],
    links: { github: '', live: 'https://www.grkprosperity.net/' }
  },
  {
    title: 'TJA Logistics',
    description: 'Enterprise logistics platform focusing on performance and professional UI for a transport company.',
    image: '/images/gallery-project/tjal.png',
    tags: ['Next.js', 'React', 'Framer Motion'],
    links: { github: '', live: 'https://www.tja-logistics.com/' }
  },
  {
    title: 'Loopback Load Tester',
    description: 'A small localhost-only load testing tool. It sends bounded high-volume GET traffic to another API already running on the same machine so you can observe latency, throughput, and error rates under pressure.',
    image: '/images/gallery-project/figma-maquette1.png',
    tags: ['Node.js', 'CLI', 'Performance'],
    links: { github: 'https://github.com/AndrixNg1/Loopback-Load-Tester', live: '' }
  },
  {
    title: 'API Mail',
    description: 'A lightweight API service for sending transactional emails programmatically with simple integration.',
    image: '/images/gallery-project/figma-maquette2.png',
    tags: ['Node.js', 'Express', 'Email'],
    links: { github: 'https://github.com/AndrixNg1/api-mail', live: '' }
  },
  {
    title: 'AndrixNg1 Portfolio',
    description: 'This very portfolio — a premium, multi-page developer showcase built with Astro, GSAP animations, and Lenis smooth scrolling.',
    image: '/images/gallery-project/figma-mobile-maquette1.png',
    tags: ['Astro', 'GSAP', 'Tailwind'],
    links: { github: 'https://github.com/AndrixNg1/andrixng1-portfolio', live: '#' }
  }
];
---

<Card>
  <SectionHeader title="Featured Projects">
    <FolderGit2 slot="icon" class="w-5 h-5" />
  </SectionHeader>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {projects.map((project) => (
      <div class="group bg-bg-secondary border border-border rounded-2xl overflow-hidden hover:border-accent-orange transition-all duration-300">
        <div class="relative h-48 md:h-56 overflow-hidden bg-bg-tertiary">
          <div class="absolute inset-0 bg-accent-orange/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 z-10"></div>
          <img 
            src={project.image} 
            alt={project.title}
            class="w-full h-full object-cover object-top group-hover:scale-105 transition-transform duration-500"
            loading="lazy"
          />
        </div>
        
        <div class="p-6">
          <h3 class="text-xl font-bold mb-2 group-hover:text-accent-orange transition-colors">{project.title}</h3>
          <p class="text-text-secondary text-sm mb-4 line-clamp-3">{project.description}</p>
          
          <div class="flex flex-wrap gap-2 mb-6">
            {project.tags.map((tag) => (
              <span class="px-2 py-1 bg-bg-tertiary border border-border rounded-md text-xs font-medium text-text-secondary">
                {tag}
              </span>
            ))}
          </div>
          
          <div class="flex items-center gap-4">
            {project.links.live && (
              <a href={project.links.live} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm font-medium text-accent-green hover:text-accent-orange transition-colors">
                <ExternalLink class="w-4 h-4" /> Live Demo
              </a>
            )}
            {project.links.github && (
              <a href={project.links.github} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm font-medium text-text-secondary hover:text-text-primary transition-colors">
                <Github class="w-4 h-4" /> Source
              </a>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
</Card>
