---
import { Briefcase, GraduationCap, Download, Calendar } from 'lucide-astro';
import Card from '../ui/Card.astro';
import SectionHeader from '../ui/SectionHeader.astro';

// Dummy data for now. We will replace this with the user's real data.
const experiences = [
  {
    company: "Tech Company Inc.",
    role: "Senior Fullstack Engineer",
    period: "2023 - Present",
    description: "Architected and implemented scalable microservices. Led a team of 4 developers to build a modern SaaS platform using React, Node.js, and PostgreSQL.",
    technologies: ["React", "Node.js", "Docker", "PostgreSQL"]
  },
  {
    company: "Digital Agency",
    role: "Frontend Developer",
    period: "2021 - 2023",
    description: "Developed cinematic, high-performance web applications with GSAP animations and Tailwind CSS. Improved SEO and core web vitals across all client sites.",
    technologies: ["Vue.js", "GSAP", "TailwindCSS", "Figma"]
  }
];

const education = [
  {
    school: "University of Technology",
    degree: "Master's in Computer Science",
    period: "2019 - 2021",
    description: "Specialized in Software Engineering and Distributed Systems. Graduated with honors."
  },
  {
    school: "Engineering Institute",
    degree: "Bachelor's in Information Technology",
    period: "2016 - 2019",
    description: "Core focus on web technologies, databases, and algorithms."
  }
];
---

<Card className="relative overflow-hidden">
  <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 w-64 h-64 bg-accent-green/10 rounded-full blur-3xl pointer-events-none"></div>
  
  <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
    <SectionHeader title="Curriculum Vitae" className="!mb-0">
      <Briefcase slot="icon" class="w-5 h-5" />
    </SectionHeader>
    
    <a 
      href="/cv.pdf" 
      download
      class="flex items-center gap-2 px-4 py-2 bg-bg-secondary border border-border hover:border-accent-green rounded-xl text-sm font-medium text-text-primary hover:text-accent-green transition-colors"
    >
      <Download class="w-4 h-4" /> Download PDF
    </a>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
    <!-- Experience Timeline -->
    <div>
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-xl bg-accent-green/10 flex items-center justify-center text-accent-green">
          <Briefcase class="w-5 h-5" />
        </div>
        <h3 class="text-xl font-bold">Experience</h3>
      </div>
      
      <div class="relative border-l border-border ml-5 space-y-8">
        {experiences.map((exp) => (
          <div class="relative pl-8 group">
            <div class="absolute -left-[5px] top-1.5 w-[9px] h-[9px] rounded-full bg-border group-hover:bg-accent-green transition-colors duration-300"></div>
            <div class="absolute -left-[1px] top-1.5 w-full h-px bg-gradient-to-r from-accent-green/50 to-transparent scale-x-0 origin-left group-hover:scale-x-100 transition-transform duration-500 z-0"></div>
            
            <div class="relative z-10 bg-bg-secondary border border-border p-5 rounded-2xl group-hover:border-accent-green transition-colors duration-300">
              <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
                <h4 class="text-lg font-bold text-text-primary">{exp.role}</h4>
                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-bg-tertiary rounded-lg text-xs font-medium text-text-muted">
                  <Calendar class="w-3 h-3" /> {exp.period}
                </span>
              </div>
              <p class="text-accent-green font-medium text-sm mb-3">{exp.company}</p>
              <p class="text-text-secondary text-sm leading-relaxed mb-4">{exp.description}</p>
              
              <div class="flex flex-wrap gap-2">
                {exp.technologies.map(tech => (
                  <span class="px-2.5 py-1 bg-bg-tertiary border border-border rounded-md text-xs font-medium text-text-muted">
                    {tech}
                  </span>
                ))}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Education Timeline -->
    <div>
      <div class="flex items-center gap-3 mb-6">
        <div class="w-10 h-10 rounded-xl bg-accent-orange/10 flex items-center justify-center text-accent-orange">
          <GraduationCap class="w-5 h-5" />
        </div>
        <h3 class="text-xl font-bold">Education</h3>
      </div>
      
      <div class="relative border-l border-border ml-5 space-y-8">
        {education.map((edu) => (
          <div class="relative pl-8 group">
            <div class="absolute -left-[5px] top-1.5 w-[9px] h-[9px] rounded-full bg-border group-hover:bg-accent-orange transition-colors duration-300"></div>
            <div class="absolute -left-[1px] top-1.5 w-full h-px bg-gradient-to-r from-accent-orange/50 to-transparent scale-x-0 origin-left group-hover:scale-x-100 transition-transform duration-500 z-0"></div>
            
            <div class="relative z-10 bg-bg-secondary border border-border p-5 rounded-2xl group-hover:border-accent-orange transition-colors duration-300">
              <div class="flex flex-wrap items-start justify-between gap-2 mb-2">
                <h4 class="text-lg font-bold text-text-primary">{edu.degree}</h4>
                <span class="inline-flex items-center gap-1.5 px-3 py-1 bg-bg-tertiary rounded-lg text-xs font-medium text-text-muted">
                  <Calendar class="w-3 h-3" /> {edu.period}
                </span>
              </div>
              <p class="text-accent-orange font-medium text-sm mb-3">{edu.school}</p>
              <p class="text-text-secondary text-sm leading-relaxed">{edu.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</Card>
