---
import { Camera, X } from 'lucide-astro';
import Card from '../ui/Card.astro';
import SectionHeader from '../ui/SectionHeader.astro';

// Use standard sizes, and use Tailwind grid spans to make it a dynamic bento layout
const photos = [
  { image: '/images/me/37f9555d-78a2-4aac-8f4a-586f32fa0043.jpeg', span: 'col-span-2 row-span-2' },
  { image: '/images/me/ac37a55f-8cd8-4251-921e-921bfa482c19.jpeg', span: 'col-span-1 row-span-1' },
  { image: '/images/me/c53e2c93-c40c-47cd-9f95-aa2b90ced2ed.jpeg', span: 'col-span-1 row-span-1' },
  { image: '/images/me/c81bae9a-f4ae-49ba-9e00-3033d71e9082.jpeg', span: 'col-span-1 row-span-1' },
  { image: '/images/even/img2.jpg', span: 'col-span-1 row-span-1' },
  { image: '/images/even/img3.jpg', span: 'col-span-2 row-span-1' }
];
---

<Card>
  <SectionHeader title="Life & Setup">
    <Camera slot="icon" class="w-5 h-5" />
  </SectionHeader>

  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 auto-rows-[150px] md:auto-rows-[200px]">
    {photos.map((photo) => (
      <button 
        type="button"
        class={`photo-trigger group relative overflow-hidden rounded-2xl border border-border bg-bg-tertiary focus:outline-none focus:ring-2 focus:ring-accent-green cursor-pointer ${photo.span}`}
        data-photo-src={photo.image}
      >
        <img 
          src={photo.image} 
          alt="Personal Photo"
          class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-700 ease-out"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-accent-green/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 backdrop-blur-[2px] flex items-center justify-center">
          <span class="w-10 h-10 bg-white/20 rounded-full flex items-center justify-center backdrop-blur-md text-white scale-0 group-hover:scale-100 transition-transform duration-500 delay-100">
            <Camera class="w-5 h-5" />
          </span>
        </div>
      </button>
    ))}
  </div>
</Card>


<dialog id="photo-lightbox" class="fixed inset-0 z-[9999] w-full h-full max-w-full max-h-full m-0 p-0 bg-transparent backdrop:bg-black/90 backdrop:backdrop-blur-sm open:flex open:items-center open:justify-center">
  <div class="relative w-[90vw] h-[90vh] flex items-center justify-center">
    <button id="lightbox-close" type="button" class="absolute top-0 right-0 p-3 bg-black/50 hover:bg-accent-green rounded-full text-white transition-colors focus:outline-none z-10" aria-label="Close lightbox">
      <X class="w-6 h-6" />
    </button>
    <img id="lightbox-img" src="" alt="Full screen view" class="max-w-full max-h-full rounded-lg shadow-2xl object-contain scale-95 opacity-0 transition-all duration-300" />
  </div>
</dialog>

<script>
  const modal = document.getElementById('photo-lightbox');
  const closeBtn = document.getElementById('lightbox-close');
  const lightboxImg = document.getElementById('lightbox-img');

  if (modal && closeBtn && lightboxImg) {
    document.querySelectorAll('.photo-trigger').forEach((btn) => {
      btn.addEventListener('click', () => {
        const src = btn.getAttribute('data-photo-src');
        if (src) {
          lightboxImg.src = src;
          modal.showModal();
          // Small delay to allow display before animating opacity/scale
          setTimeout(() => {
            lightboxImg.classList.remove('scale-95', 'opacity-0');
            lightboxImg.classList.add('scale-100', 'opacity-100');
          }, 10);
        }
      });
    });

    const closeModal = () => {
      lightboxImg.classList.remove('scale-100', 'opacity-100');
      lightboxImg.classList.add('scale-95', 'opacity-0');
      setTimeout(() => {
        modal.close();
        lightboxImg.src = '';
      }, 300);
    };

    closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
  }
</script>
