---
import { Settings2, MonitorSmartphone, ServerCog, Cpu, CloudCog, Palette, ShieldCheck } from 'lucide-astro';

const services = [
  { title: "Web Development", icon: MonitorSmartphone, desc: "Building responsive, performant, and accessible web applications." },
  { title: "Mobile Development", icon: MonitorSmartphone, desc: "Creating cross-platform mobile experiences with React Native & Flutter." },
  { title: "Backend Architecture", icon: ServerCog, desc: "Designing scalable and secure backend systems and databases." },
  { title: "API Engineering", icon: Cpu, desc: "Developing robust REST and GraphQL APIs for seamless integration." },
  { title: "SaaS Development", icon: CloudCog, desc: "End-to-end development of modern SaaS platforms." },
  { title: "UI/UX Integration", icon: Palette, desc: "Translating complex designs into pixel-perfect frontend code." },
  { title: "DevOps & Cloud", icon: ShieldCheck, desc: "Automating deployments and managing cloud infrastructure." }
];
---

<section id="services" class="bg-bg-primary border border-border rounded-3xl p-6 md:p-10 shadow-[var(--card-shadow)] relative">
  <div class="flex items-center gap-3 mb-8">
    <Settings2 class="w-6 h-6 text-accent-blue" />
    <h2 class="text-2xl font-bold">Services</h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
    {services.map((service) => (
      <div class="group p-6 rounded-2xl bg-bg-secondary border border-border hover:border-accent-blue/50 transition-all duration-300 relative overflow-hidden">
        <div class="absolute inset-0 bg-gradient-to-br from-accent-blue/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
        <div class="relative z-10">
          <div class="w-12 h-12 rounded-xl bg-bg-primary border border-border flex items-center justify-center text-accent-blue mb-4 group-hover:scale-110 group-hover:bg-accent-blue/10 transition-transform duration-300">
            <service.icon class="w-6 h-6" />
          </div>
          <h3 class="text-lg font-bold mb-2">{service.title}</h3>
          <p class="text-sm text-text-secondary leading-relaxed">{service.desc}</p>
        </div>
      </div>
    ))}
  </div>
</section>
