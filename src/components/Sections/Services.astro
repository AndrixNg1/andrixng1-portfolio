---
import { Settings2, MonitorSmartphone, ServerCog, Cpu, CloudCog, Palette, ShieldCheck } from 'lucide-astro';
import Card from '../ui/Card.astro';
import SectionHeader from '../ui/SectionHeader.astro';

const services = [
  {
    title: 'Frontend Development',
    description: 'Building high-performance, accessible, and cinematic user interfaces using modern frameworks like React, Next.js, and Astro.',
    icon: MonitorSmartphone,
    color: 'text-accent-green',
    bg: 'bg-accent-green/10'
  },
  {
    title: 'Backend Engineering',
    description: 'Architecting robust, scalable, and secure server-side applications and APIs with Node.js, Python, and Go.',
    icon: ServerCog,
    color: 'text-accent-orange',
    bg: 'bg-accent-orange/10'
  },
  {
    title: 'Cloud Architecture',
    description: 'Designing and deploying resilient infrastructure on AWS and GCP with modern DevOps practices and Docker.',
    icon: CloudCog,
    color: 'text-blue-500',
    bg: 'bg-blue-500/10'
  },
  {
    title: 'UI/UX & Motion Design',
    description: 'Crafting premium digital experiences with fluid GSAP animations, glassmorphism, and intuitive interactions.',
    icon: Palette,
    color: 'text-purple-500',
    bg: 'bg-purple-500/10'
  }
];
---

<Card>
  <SectionHeader title="My Services">
    <Settings2 slot="icon" class="w-5 h-5" />
  </SectionHeader>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    {services.map((service) => (
      <div class="p-6 bg-bg-secondary border border-border rounded-2xl hover:border-accent-green hover:bg-bg-tertiary transition-all duration-300 group">
        <div class={`w-12 h-12 rounded-xl ${service.bg} flex items-center justify-center mb-4 group-hover:scale-110 transition-transform duration-300`}>
          <service.icon class={`w-6 h-6 ${service.color}`} />
        </div>
        <h3 class="text-xl font-bold mb-3">{service.title}</h3>
        <p class="text-text-secondary leading-relaxed">{service.description}</p>
      </div>
    ))}
  </div>
</Card>
