---
import { Image as ImageIcon } from 'lucide-astro';
import Card from '../ui/Card.astro';
import SectionHeader from '../ui/SectionHeader.astro';

const designs = await Astro.glob('../../data/designs/*.md');
// Sort by order frontmatter
designs.sort((a, b) => a.frontmatter.order - b.frontmatter.order);
---

<Card>
  <SectionHeader title="Design Gallery">
    <ImageIcon slot="icon" class="w-5 h-5" />
  </SectionHeader>

  <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
    {designs.map((design) => {
      const slug = design.file.split('/').pop().replace('.md', '');
      return (
        <a
          href={`/design/${slug}`}
          class="group relative overflow-hidden rounded-2xl break-inside-avoid border border-border bg-bg-tertiary w-full block text-left focus:outline-none focus:ring-2 focus:ring-accent-green shadow-sm hover:shadow-2xl hover:shadow-accent-green/10 transition-all duration-500"
        >
          <img 
            src={design.frontmatter.thumbnail} 
            alt={design.frontmatter.title}
            class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-5">
            <div class="translate-y-4 group-hover:translate-y-0 transition-transform duration-300">
              <h4 class="text-white font-bold text-lg mb-1">{design.frontmatter.title}</h4>
              <p class="text-accent-green text-sm font-medium">View Project &rarr;</p>
            </div>
          </div>
        </a>
      );
    })}
  </div>
</Card>
