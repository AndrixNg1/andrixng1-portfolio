---
import { ImageIcon, Maximize2 } from 'lucide-astro';

// Dummy data for gallery
const galleryItems = [
  { id: 1, height: "h-64", span: "md:col-span-2 md:row-span-2", title: "Dashboard Preview" },
  { id: 2, height: "h-48", span: "md:col-span-1 md:row-span-1", title: "Mobile UI" },
  { id: 3, height: "h-48", span: "md:col-span-1 md:row-span-1", title: "SaaS Interface" },
  { id: 4, height: "h-64", span: "md:col-span-1 md:row-span-2", title: "Backend System" },
  { id: 5, height: "h-64", span: "md:col-span-1 md:row-span-2", title: "UI Concept" }
];
---

<section id="gallery" class="bg-bg-primary border border-border rounded-3xl p-6 md:p-10 shadow-[var(--card-shadow)] relative">
  <div class="flex items-center gap-3 mb-8">
    <ImageIcon class="w-6 h-6 text-accent-blue" />
    <h2 class="text-2xl font-bold">Project Gallery</h2>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-3 auto-rows-min gap-4">
    {galleryItems.map((item) => (
      <div class={`group relative overflow-hidden rounded-2xl bg-bg-tertiary border border-border cursor-pointer ${item.span} ${item.height}`}>
        <div class="absolute inset-0 bg-[url('data:image/svg+xml;base64,PHN2ZyB3aWR0aD0iMjAiIGhlaWdodD0iMjAiIHhtbG5zPSJodHRwOi8vd3d3LnczLm9yZy8yMDAwL3N2ZyI+PGNpcmNsZSBjeD0iMiIgY3k9IjIiIHI9IjIiIGZpbGw9IiM2YjcyODAiIGZpbGwtb3BhY2l0eT0iMC4yIi8+PC9zdmc+')] opacity-50 mix-blend-overlay"></div>
        
        <!-- Hover Overlay -->
        <div class="absolute inset-0 bg-black/60 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex flex-col items-center justify-center gap-2 z-10 backdrop-blur-sm">
          <div class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white scale-0 group-hover:scale-100 transition-transform duration-500 delay-100">
            <Maximize2 class="w-6 h-6" />
          </div>
          <span class="text-white font-medium translate-y-4 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500 delay-200">
            {item.title}
          </span>
        </div>
        
        <!-- Image placeholder graphic -->
        <div class="absolute inset-0 flex items-center justify-center text-text-muted group-hover:scale-110 transition-transform duration-700">
          <ImageIcon class="w-12 h-12 opacity-20" />
        </div>
      </div>
    ))}
  </div>
</section>
