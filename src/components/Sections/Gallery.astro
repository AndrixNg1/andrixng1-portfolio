---
import { Image as ImageIcon, Maximize2 } from 'lucide-astro';
import Card from '../ui/Card.astro';
import SectionHeader from '../ui/SectionHeader.astro';

const galleryItems = [
  { image: '/images/gallery-project/figma-maquette1.png', alt: 'Figma Maquette 1' },
  { image: '/images/gallery-project/figma-maquette2.png', alt: 'Figma Maquette 2' },
  { image: '/images/gallery-project/figma-mobile-maquette1.png', alt: 'Figma Mobile' },
  { image: '/images/gallery-project/grk.png', alt: 'GRK Prosperity' },
  { image: '/images/gallery-project/tjal.png', alt: 'TJA Logistics' }
];
---

<Card>
  <SectionHeader title="Design Gallery">
    <ImageIcon slot="icon" class="w-5 h-5" />
  </SectionHeader>

  <div class="columns-1 sm:columns-2 lg:columns-3 gap-4 space-y-4">
    {galleryItems.map((item) => (
      <div class="group relative overflow-hidden rounded-2xl break-inside-avoid border border-border bg-bg-tertiary">
        <img 
          src={item.image} 
          alt={item.alt}
          class="w-full h-auto object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
          loading="lazy"
        />
        <div class="absolute inset-0 bg-accent-green/80 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center backdrop-blur-sm cursor-pointer">
          <Maximize2 class="w-8 h-8 text-white scale-50 group-hover:scale-100 transition-transform duration-500 delay-100" />
        </div>
      </div>
    ))}
  </div>
</Card>
