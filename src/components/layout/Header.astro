---
const navItems = [
  { label: "Profile", href: "#profile", number: "01" },
  { label: "Experience", href: "#presentation", number: "02" },
  { label: "Capabilities", href: "#capabilities", number: "03" },
  { label: "Projects", href: "#projects", number: "04" },
  { label: "Contact", href: "#contact", number: "05" },
];
---

<header class="fixed inset-x-0 top-0 z-50 border-b border-[var(--line)] bg-[var(--header-bg)] backdrop-blur-xl">
  <div class="mx-auto flex h-20 w-[calc(100%_-_2rem)] max-w-[1440px] items-center justify-between gap-4 lg:h-[5.5rem] lg:w-[calc(100%_-_3rem)]">
    <a class="group flex items-center gap-3 text-[var(--text)]" href="/" aria-label="Andrix Ng home">
      <img class="h-9 w-9 object-contain transition-transform duration-500 group-hover:-rotate-6 group-hover:scale-110 lg:h-10 lg:w-10" src="/images/logo/andrix-ng.png" alt="" />
      <span class="hidden items-center font-sans text-[0.95rem] tracking-[0.15em] sm:flex">
        <strong class="font-black uppercase text-[var(--text)]">Andrix</strong>
        <span class="mx-[2px] text-xl font-black text-[var(--cyan)] leading-none mb-1">.</span>
        <span class="font-medium uppercase text-[var(--muted)]">Ng</span>
      </span>
    </a>

    <nav class="hidden items-center gap-1 lg:flex" aria-label="Main navigation">
      {
        navItems.map((item) => (
          <a class="inline-flex items-center gap-1.5 px-3 py-2 text-[11px] font-extrabold uppercase tracking-wide text-[var(--muted)] transition hover:bg-[color-mix(in_srgb,var(--cyan)_10%,transparent)] hover:text-[var(--text)]" href={item.href}>
            <span class="font-mono text-[10px] text-[color-mix(in_srgb,var(--cyan)_72%,transparent)]">{item.number}</span>
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-2">
      <button class="theme-toggle flex items-center justify-center rounded-full border border-[var(--line)] bg-[var(--surface)] text-[var(--text)] transition-colors hover:bg-[color-mix(in_srgb,var(--cyan)_12%,transparent)]" type="button" data-theme-toggle aria-label="Switch color theme" aria-pressed="false" style="width: 2.5rem; height: 2.5rem;">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="dark-icon block"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="light-icon hidden"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
      </button>
      <a class="inline-flex min-h-10 items-center justify-center bg-[var(--cyan)] px-4 text-[11px] font-black uppercase tracking-[0.12em] text-white transition hover:bg-[var(--cyan-strong)] sm:px-5" href="#contact">Available</a>
    </div>
  </div>
</header>
