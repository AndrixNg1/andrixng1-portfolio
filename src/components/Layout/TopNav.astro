---
import ThemeToggle from '../ThemeToggle.astro';
import { User, FolderGit2, Image as ImageIcon, CalendarDays, Settings2, Mail, Download } from 'lucide-astro';

const navItems = [
  { name: 'About', icon: User, href: '/' },
  { name: 'Projects', icon: FolderGit2, href: '/projects' },
  { name: 'Gallery', icon: ImageIcon, href: '/gallery' },
  { name: 'Contact', icon: Mail, href: '/contact' },
];
---

<nav class="w-full bg-bg-primary border border-border rounded-2xl p-4 shadow-[var(--card-shadow)] sticky top-8 z-50 flex items-center justify-between gap-4 overflow-x-auto custom-scrollbar">
  <ul class="flex items-center gap-2 md:gap-6 min-w-max">
    {navItems.map((item) => (
      <li>
        <a href={item.href} class="flex items-center gap-2 text-sm font-medium text-text-secondary hover:text-accent-green transition-colors px-2 py-1 rounded-lg hover:bg-bg-secondary">
          <item.icon class="w-4 h-4" />
          <span class="hidden sm:inline">{item.name}</span>
        </a>
      </li>
    ))}
  </ul>

  <div class="flex items-center gap-4 shrink-0">
    <ThemeToggle />
    <button class="flex items-center gap-2 bg-accent-green hover:bg-accent-orange text-white px-4 py-2 rounded-xl text-sm font-medium transition-colors shadow-lg shadow-accent-green/20">
      <Download class="w-4 h-4" />
      <span class="hidden sm:inline">Download CV</span>
    </button>
  </div>
</nav>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    height: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 4px;
  }
</style>
