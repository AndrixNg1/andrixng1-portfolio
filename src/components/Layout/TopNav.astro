---
import { User, FolderGit2, Image as ImageIcon, Mail } from 'lucide-astro';

const navItems = [
  { name: 'About', icon: User, href: '/' },
  { name: 'Projects', icon: FolderGit2, href: '/projects' },
  { name: 'Gallery', icon: ImageIcon, href: '/gallery' },
  { name: 'Contact', icon: Mail, href: '/contact' },
];
---

<nav class="sticky top-8 z-40 w-full bg-bg-primary/80 backdrop-blur-md border border-border rounded-2xl p-2 flex items-center justify-between shadow-[var(--card-shadow)]">
  <ul class="flex items-center gap-1 sm:gap-2 w-full overflow-x-auto custom-scrollbar">
    {navItems.map((item) => (
      <li class="flex-1">
        <a 
          href={item.href}
          class="flex items-center justify-center gap-2 px-4 py-3 rounded-xl text-sm font-medium text-text-secondary hover:bg-bg-tertiary hover:text-text-primary transition-all duration-300"
        >
          <item.icon class="w-4 h-4" />
          <span class="hidden sm:inline">{item.name}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    height: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 4px;
  }
</style>
