---
import { MapPin, Mail, Link as LinkIcon, Linkedin, Github, Instagram, Award, Briefcase, GraduationCap } from 'lucide-astro';
---

<aside class="w-full lg:w-[320px] shrink-0 lg:sticky lg:top-8 h-auto lg:h-[calc(100vh-4rem)] bg-bg-primary border border-border rounded-3xl p-6 shadow-[var(--card-shadow)] flex flex-col gap-6 z-10 overflow-y-auto custom-scrollbar">
  <!-- Profile Info -->
  <div class="flex flex-col items-center text-center">
    <div class="relative w-32 h-32 mb-4 group cursor-pointer">
      <!-- Glow effect behind image -->
      <div class="absolute inset-0 bg-accent-green/20 rounded-full blur-xl group-hover:bg-accent-orange/40 transition-colors duration-500"></div>
      
      <!-- Profile Image -->
      <div class="relative w-full h-full rounded-full border-4 border-bg-primary overflow-hidden bg-bg-tertiary">
        <img 
          src="/images/me/home.jpeg" 
          alt="AndrixNg1" 
          class="w-full h-full object-cover"
        />
      </div>
      <!-- Online Indicator -->
      <div class="absolute bottom-1 right-1 w-5 h-5 bg-green-500 border-4 border-bg-primary rounded-full"></div>
    </div>
    
    <h1 class="text-2xl font-bold flex items-center gap-2">
      AndrixNg1 
      <svg class="w-5 h-5 text-accent-green" viewBox="0 0 24 24" fill="currentColor"><path d="M10 15.172l9.192-9.193 1.415 1.414L10 18l-6.364-6.364 1.414-1.414z"/></svg>
    </h1>
    <p class="text-text-secondary font-medium mt-1">Software Engineer</p>
    <p class="text-sm text-text-muted mt-2">Crafting elegant scalable digital solutions with impact.</p>
    
    <a href="/contact" class="w-full mt-6 py-2.5 bg-accent-green hover:bg-accent-orange text-white rounded-xl font-medium transition-colors shadow-lg shadow-accent-green/20 group relative overflow-hidden flex items-center justify-center gap-2">
      <span class="relative z-10 flex items-center justify-center gap-2">
        <Mail class="w-4 h-4" /> Contact Me
      </span>
      <div class="absolute inset-0 bg-white/20 translate-y-full group-hover:translate-y-0 transition-transform duration-300 ease-in-out"></div>
    </a>
  </div>

  <div class="h-px bg-border w-full"></div>

  <!-- Contact / Links -->
  <ul class="flex flex-col gap-4 text-sm">
    <li class="flex items-center gap-3 text-text-secondary hover:text-accent-green transition-colors">
      <MapPin class="w-4 h-4" />
      <span>DR Congo, Lubumbashi</span>
    </li>
    <li class="flex items-center gap-3 text-text-secondary hover:text-accent-green transition-colors">
      <Mail class="w-4 h-4" />
      <a href="mailto:andrixngoyi243@gmail.com" class="truncate">andrixngoyi243@gmail.com</a>
    </li>
    <li class="flex items-center gap-3 text-text-secondary hover:text-accent-green transition-colors">
      <LinkIcon class="w-4 h-4" />
      <a href="https://andrixngoyi.vercel.app/" target="_blank" rel="noopener noreferrer" class="truncate">andrixngoyi.vercel.app</a>
    </li>
  </ul>

  <!-- Socials -->
  <div class="flex flex-col gap-3 text-sm mt-2">
    <a href="https://github.com/AndrixNg1" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-text-secondary hover:text-text-primary transition-colors">
      <Github class="w-4 h-4" />
      <span>AndrixNg1</span>
    </a>
    <a href="https://www.linkedin.com/in/andrix-ngoyi-469662321/" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-text-secondary hover:text-accent-green transition-colors">
      <Linkedin class="w-4 h-4" />
      <span>Andrix Ngoyi</span>
    </a>
    <a href="https://x.com/andr6102" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-text-secondary hover:text-text-primary transition-colors">
      <!-- X (Twitter) icon -->
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      <span>@andr6102</span>
    </a>
    <a href="https://wa.me/243836066402" target="_blank" rel="noopener noreferrer" class="flex items-center gap-3 text-text-secondary hover:text-green-500 transition-colors">
      <!-- WhatsApp icon -->
      <svg class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      <span>+243 836 066 402</span>
    </a>
    <a href="#" class="flex items-center gap-3 text-text-secondary hover:text-pink-500 transition-colors">
      <Instagram class="w-4 h-4" />
      <span>andrix_ngoyi</span>
    </a>
  </div>

  <div class="h-px bg-border w-full mt-2"></div>

  <!-- Achievements -->
  <div>
    <h3 class="text-sm font-semibold mb-3">Achievements</h3>
    <div class="flex gap-2">
      <div class="w-10 h-10 rounded-full bg-green-100 dark:bg-green-900/30 border border-green-200 dark:border-green-800 flex items-center justify-center text-green-600 cursor-pointer hover:scale-110 transition-transform">
        <Award class="w-5 h-5" />
      </div>
      <div class="w-10 h-10 rounded-full bg-orange-100 dark:bg-orange-900/30 border border-orange-200 dark:border-orange-800 flex items-center justify-center text-orange-600 cursor-pointer hover:scale-110 transition-transform">
        <Briefcase class="w-5 h-5" />
      </div>
      <div class="w-10 h-10 rounded-full bg-purple-100 dark:bg-purple-900/30 border border-purple-200 dark:border-purple-800 flex items-center justify-center text-purple-600 cursor-pointer hover:scale-110 transition-transform">
        <GraduationCap class="w-5 h-5" />
      </div>
    </div>
  </div>
</aside>

<style>
  .custom-scrollbar::-webkit-scrollbar {
    width: 4px;
  }
  .custom-scrollbar::-webkit-scrollbar-track {
    background: transparent;
  }
  .custom-scrollbar::-webkit-scrollbar-thumb {
    background: var(--border);
    border-radius: 4px;
  }
</style>
