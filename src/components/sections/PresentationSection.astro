---
import SectionLabel from "../ui/SectionLabel.astro";
import { presentationSlides } from "../../data/page-content";
---

<section id="presentation" class="presentation-section relative bg-[var(--bg)] pt-24 text-[var(--text)]">
  <div class="presentation-mobile-title mx-auto mb-8 w-[calc(100%_-_2rem)] max-w-[1440px] lg:hidden">
    <SectionLabel number="02" label="Education & Experience" />
    <h2 class="max-w-3xl text-[clamp(2.4rem,12vw,4rem)] font-black uppercase leading-[0.92]">The work, in three concrete moves.</h2>
  </div>

  <div class="presentation-mobile-list lg:hidden">
    {
      presentationSlides.map((slide) => (
        <article>
          <img src={slide.image} alt={slide.alt} loading="lazy" decoding="async" />
          <div>
            <p>{slide.number} / {slide.kicker}</p>
            <h3>{slide.title}</h3>
            <span>{slide.body}</span>
          </div>
        </article>
      ))
    }
  </div>

  <div class="presentation-desktop relative border-y border-[var(--line)] bg-[var(--bg)] block" data-presentation-scroll>
    <div class="presentation-bg absolute inset-0" aria-hidden="true"></div>
    <div class="presentation-layout relative mx-auto grid w-[calc(100%_-_2rem)] lg:w-[calc(100%_-_5rem)] max-w-[1440px] grid-cols-1 lg:grid-cols-[5fr_7fr] gap-8 lg:gap-16">
      <div>
        <div class="presentation-sticky sticky top-0 flex h-[45vh] lg:h-screen flex-col justify-end pb-8 lg:pb-0 lg:justify-center z-20 bg-[var(--bg)] lg:bg-transparent">
          <SectionLabel number="02" label="Education & Experience" />
          <h2 class="max-w-xl text-[clamp(2.5rem,4.8vw,5.1rem)] font-black uppercase leading-[0.9]">Ideas<br />to systems.</h2>

          <div class="presentation-copy-stack relative mt-8 lg:mt-12 min-h-64 lg:min-h-96">
            {
              presentationSlides.map((slide, index) => (
                <article class={`presentation-copy absolute inset-0 ${index === 0 ? "is-active" : ""}`} data-presentation-copy={index} aria-hidden={index === 0 ? "false" : "true"}>
                  <p class="font-mono text-[10px] lg:text-xs font-black uppercase tracking-[0.26em] text-[var(--cyan)]">{slide.number} / {slide.kicker}</p>
                  <h3 class="mt-3 lg:mt-5 mb-4 lg:mb-6 max-w-xl text-[clamp(1.5rem,3vw,3.2rem)] font-black leading-[0.95]">{slide.title}</h3>
                  <span class="block max-w-xl text-sm lg:text-lg leading-6 lg:leading-8 text-[var(--muted)] line-clamp-3 lg:line-clamp-none">{slide.body}</span>
                  <strong class="mt-4 lg:mt-8 inline-flex border-l-4 border-[var(--orange)] bg-[color-mix(in_srgb,var(--cyan)_12%,transparent)] px-4 py-3 lg:px-5 lg:py-4 font-mono text-[10px] lg:text-xs font-black uppercase tracking-[0.22em] text-[#9fd8e5]">{slide.metric}</strong>
                </article>
              ))
            }
          </div>

          <div class="presentation-dots mt-4 lg:mt-8 flex gap-3" aria-hidden="true">
            {presentationSlides.map((_, index) => <span class={index === 0 ? "is-active" : ""} data-presentation-dot={index}></span>)}
          </div>
        </div>
      </div>

      <div class="presentation-image-column grid gap-16 lg:gap-24 py-[45vh] lg:py-[18vh]">
        {
          presentationSlides.map((slide, index) => (
            <figure class="presentation-image-card relative m-0 min-h-[50vh] lg:min-h-[76vh] overflow-hidden border border-[var(--line)] bg-[#101416] shadow-[0_32px_90px_var(--shadow-accent)]" data-presentation-card={index}>
              <img class="absolute inset-0 h-full w-full object-cover object-top" src={slide.image} alt={slide.alt} loading={index === 0 ? "eager" : "lazy"} decoding="async" />
              <figcaption class="absolute inset-x-4 lg:inset-x-6 bottom-4 lg:bottom-6 z-10 flex justify-between gap-4">
                <span class="bg-white/90 px-3 py-2 lg:px-4 lg:py-3 font-mono text-[9px] lg:text-[11px] font-black uppercase tracking-[0.22em] text-[var(--cyan-strong)]">{slide.kicker}</span>
                <strong class="bg-[var(--orange)] px-3 py-2 lg:px-4 lg:py-3 font-mono text-[9px] lg:text-[11px] font-black uppercase tracking-[0.22em] text-white">{slide.number}</strong>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </div>
</section>
