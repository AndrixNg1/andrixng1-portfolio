---
import Button from "../ui/Button.astro";
import SectionLabel from "../ui/SectionLabel.astro";
import { profile } from "../../data/profile";
---

<section class="mx-auto mb-12 grid w-[calc(100%_-_2rem)] max-w-[1440px] gap-12 border border-[var(--line)] bg-[radial-gradient(circle_at_84%_16%,rgba(62,151,173,0.22),transparent_30%),var(--surface-strong)] p-6 lg:w-[calc(100%_-_3rem)] lg:grid-cols-[minmax(0,1.1fr)_minmax(320px,0.9fr)] lg:p-20" id="contact">
  <div>
    <SectionLabel number="06" label="Contact" />
    <h2 class="text-[clamp(1.8rem,3vw,3.5rem)] font-black uppercase leading-[1.1] text-[var(--text)]">Have a project, an opportunity, or a collaboration in mind? Let’s talk.</h2>
    <p class="mt-8 max-w-3xl leading-8 text-[var(--muted)]">I am available for freelance projects or full-time opportunities. Reach out to discuss your technical challenges or the creation of your next digital products.</p>

    <div class="mt-10 grid gap-px bg-[var(--line)] sm:grid-cols-2 xl:grid-cols-4">
      {
        profile.stats.map((stat) => (
          <article class="min-h-28 bg-[color-mix(in_srgb,var(--panel)_86%,transparent)] p-5">
            <strong class="block text-[clamp(1.7rem,4vw,3rem)] font-black leading-none text-[var(--orange)]">{stat.value}</strong>
            <span class="mt-3 block text-xs font-extrabold uppercase tracking-[0.1em] text-[var(--muted)]">{stat.label}</span>
          </article>
        ))
      }
    </div>
  </div>

  <div class="grid content-end gap-3">
    <Button class="group w-full justify-start overflow-hidden transition-all duration-300 hover:pr-8 break-all" href={`mailto:${profile.email}`}>
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
      {profile.email}
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-auto opacity-0 -translate-x-4 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </Button>
    <Button class="group w-full justify-start overflow-hidden transition-all duration-300 hover:pr-8" href={profile.whatsapp} variant="secondary" target="_blank" rel="noopener noreferrer">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1"><path d="M3 21l1.65-3.8a9 9 0 1 1 3.4 2.9L3 21"/><path d="M9 10a.5.5 0 0 0 1 0V9a.5.5 0 0 0-1 0v1a5 5 0 0 0 5 5h1a.5.5 0 0 0 0-1h-1a.5.5 0 0 0 0 1"/></svg>
      WhatsApp
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-auto opacity-0 -translate-x-4 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </Button>
    <Button class="group w-full justify-start overflow-hidden transition-all duration-300 hover:pr-8" href={profile.linkedin} variant="secondary" target="_blank" rel="noopener noreferrer">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect width="4" height="12" x="2" y="9"/><circle cx="4" cy="4" r="2"/></svg>
      LinkedIn
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-auto opacity-0 -translate-x-4 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </Button>
    <Button class="group w-full justify-start overflow-hidden transition-all duration-300 hover:pr-8" href={profile.github} variant="secondary" target="_blank" rel="noopener noreferrer">
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mr-1"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/><path d="M9 18c-4.51 2-5-2-7-2"/></svg>
      GitHub
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ml-auto opacity-0 -translate-x-4 transition-all duration-300 group-hover:opacity-100 group-hover:translate-x-0"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
    </Button>
  </div>
</section>
