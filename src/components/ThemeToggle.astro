---
import { Sun, Moon } from 'lucide-astro';
---

<button
  id="theme-toggle"
  class="relative p-2 rounded-full bg-bg-secondary border border-border text-text-secondary hover:text-accent-green transition-colors duration-300 focus:outline-none focus:ring-2 focus:ring-accent-green"
  aria-label="Toggle theme"
>
  <span class="sr-only">Toggle theme</span>
  <Sun class="w-5 h-5 absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 transition-transform duration-300 dark:scale-0 dark:-rotate-90" />
  <Moon class="w-5 h-5 absolute top-1/2 left-1/2 transform -translate-x-1/2 -translate-y-1/2 transition-transform duration-300 scale-0 rotate-90 dark:scale-100 dark:rotate-0" />
</button>

<script>
  import { initThemeToggle } from '../assets/js/themeToggle.js';
  
  initThemeToggle();
</script>
