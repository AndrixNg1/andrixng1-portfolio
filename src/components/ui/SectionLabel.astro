---
interface Props {
  number: string;
  label: string;
  class?: string;
}

const { number, label, class: className = "" } = Astro.props;
---

<p class={`section-label flex items-center gap-3 text-[11px] font-black uppercase tracking-[0.3em] text-[var(--muted)] ${className}`}>
  <span class="font-mono text-[var(--cyan)]">{number}</span>
  {label}
</p>
