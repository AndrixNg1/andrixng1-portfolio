---
interface Props {
  href: string;
  variant?: "primary" | "secondary";
  class?: string;
  target?: string;
  rel?: string;
}

const {
  href,
  variant = "primary",
  class: className = "",
  target,
  rel,
} = Astro.props;

const variantClass = variant === "primary"
  ? "bg-[var(--cyan)] text-white hover:bg-[var(--cyan-strong)]"
  : "border border-[color-mix(in_srgb,var(--cyan)_42%,transparent)] bg-white/8 text-[var(--text)] backdrop-blur hover:border-[var(--cyan)] hover:bg-[color-mix(in_srgb,var(--cyan)_12%,transparent)]";
---

<a
  href={href}
  target={target}
  rel={rel}
  class={`btn inline-flex min-h-14 items-center justify-center gap-2 px-7 text-[13px] font-black uppercase tracking-[0.08em] transition hover:-translate-y-0.5 ${variantClass} ${className}`}
>
  <slot />
</a>
