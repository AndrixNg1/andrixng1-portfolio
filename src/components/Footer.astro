---
import { Heart } from 'lucide-astro';
---

<footer class="w-full py-8 border-t border-border mt-8 flex flex-col md:flex-row items-center justify-between gap-4 text-sm text-text-muted">
  <div class="flex items-center gap-2">
    <span>© {new Date().getFullYear()} Andrix Ngoyi. All rights reserved.</span>
    <span class="w-1.5 h-1.5 rounded-full bg-accent-green"></span>
    <span class="hidden sm:inline">Built with Astro & Tailwind</span>
  </div>
  
  <div class="flex items-center gap-2">
    <span>Crafted with</span>
    <Heart class="w-4 h-4 text-accent-orange fill-current animate-pulse" />
    <span>in DRC</span>
  </div>
</footer>
