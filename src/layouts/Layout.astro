---
import ThemeToggle from '../components/ThemeToggle.astro';
import Sidebar from '../components/Layout/Sidebar.astro';
import TopNav from '../components/Layout/TopNav.astro';
import Footer from '../components/Footer.astro';
import '../assets/styles/app.css';

interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/jpeg" href="/images/logo/andrix-ng.png" />
		<meta name="generator" content={Astro.generator} />
		
		<!-- SEO -->
		<title>{title}</title>
		<meta name="description" content="Fullstack Software Engineer specializing in scalable backend systems, modern frontend development, SaaS platforms, API engineering, DevOps and immersive digital experiences. Explore projects, UI/UX designs, SmartCity Lite, AOI-Mail and more." />
		<meta name="keywords" content="AndrixNg1, Fullstack Developer, Software Engineer, Backend Developer, Frontend Developer, Laravel Developer, PHP Developer, Astro Developer, GSAP Portfolio, DevOps Engineer, API Engineer, Modern Web Developer, SaaS Developer, SmartCity Lite, Portfolio Developer, UI UX Designer, JavaScript Developer, TypeScript Developer, Node.js Developer, React Developer, Flutter Developer, Cloud Engineer, Performance Optimization, Web Application Developer, Mobile Application Developer, Tech Portfolio" />
		<meta name="author" content="AndrixNg1" />
		
		<!-- Open Graph -->
		<meta property="og:title" content="AndrixNg1 — Fullstack Software Engineer & SaaS Builder" />
		<meta property="og:description" content="Building scalable backend systems, immersive frontend experiences and modern SaaS platforms with Astro, GSAP, Laravel, Node.js and modern web technologies." />
		<meta property="og:image" content="/images/logo/andrix-ng.png" />
		<meta property="og:type" content="website" />
		<meta property="og:url" content="https://andrixng1.com" />
		
		<!-- Twitter / X -->
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content="AndrixNg1 — Fullstack Software Engineer & SaaS Builder" />
		<meta name="twitter:description" content="Creative Fullstack Engineer crafting scalable digital products, modern interfaces and immersive web experiences." />
		<meta name="twitter:image" content="/images/logo/andrix-ng.png" />

		<!-- JSON-LD -->
		<script type="application/ld+json">
		{
			"@context": "https://schema.org",
			"@type": "Person",
			"name": "AndrixNg1",
			"jobTitle": "Fullstack Software Engineer",
			"description": "Fullstack Software Engineer specialized in backend systems, SaaS platforms, APIs, DevOps and modern frontend experiences.",
			"url": "https://andrixng1.com",
			"sameAs": [
				"https://github.com/AndrixNg1",
				"https://linkedin.com/in/andrix-ngoyi-469662321/",
				"https://x.com/andr6102"
			],
			"knowsAbout": [
				"Laravel",
				"PHP",
				"Node.js",
				"Astro",
				"GSAP",
				"TypeScript",
				"Flutter",
				"DevOps",
				"API Engineering",
				"UI UX Design"
			]
		}
		</script>
		
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/devicons/devicon@latest/devicon.min.css">
	</head>
	<body class="bg-bg-primary text-text-primary antialiased min-h-screen selection:bg-accent-green/30 selection:text-accent-green overflow-x-hidden font-sans">
		
		<div class="max-w-[1400px] mx-auto p-4 md:p-8 flex flex-col lg:flex-row gap-8 relative">
			<Sidebar />

			<main class="flex-1 flex flex-col gap-8 min-w-0">
				<TopNav />

				<div class="flex flex-col gap-8" id="content-sections">
					<slot />
				</div>

				<Footer />
			</main>
		</div>

		<script>
			import { initThemeToggle } from '../assets/js/themeToggle.js';
			import { initLenis } from '../assets/js/lenisSetup.js';
			import { initPageAnimations } from '../assets/js/animations.js';

			initThemeToggle();
			initLenis();
			initPageAnimations();
		</script>
	</body>
</html>
