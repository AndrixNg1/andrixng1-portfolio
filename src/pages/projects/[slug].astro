---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { projects } from "../../data/projects";
import Button from "../../components/ui/Button.astro";

export async function getStaticPaths() {
  return projects.map((project) => ({
    params: { slug: project.title.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/(^-|-$)/g, "") },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<BaseLayout
  title={`${project.title} | Case Study`}
  description={project.description}
>
  <article class="relative min-h-screen bg-[var(--bg)] text-[var(--text)] pb-32">
    
    {/* Header / Hero Section */}
    <header class="relative pt-32 pb-16 lg:pt-48 lg:pb-24">
      <div class="mx-auto w-[calc(100%_-_2rem)] max-w-[1440px] lg:w-[calc(100%_-_3rem)]">
        <div class="mb-10 flex items-center gap-4">
          <a
            href="/#projects"
            class="group inline-flex items-center gap-2 text-[11px] font-black uppercase tracking-[0.18em] text-[var(--muted)] transition-colors hover:text-[var(--text)]"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="transition-transform duration-300 group-hover:-translate-x-1"
            >
              <path d="m15 18-6-6 6-6"></path>
            </svg>
            Back to Projects
          </a>
          <span class="text-[var(--line)]">|</span>
          <span class="text-[11px] font-black uppercase tracking-[0.18em] text-[var(--cyan)]">{project.category}</span>
        </div>

        <div class="grid gap-12 lg:grid-cols-[1fr_minmax(320px,auto)] lg:items-end">
          <div>
            <h1 class="mb-8 text-[clamp(2.5rem,6vw,5.5rem)] font-black uppercase leading-[0.9] tracking-tight text-[var(--text)]">
              {project.title}
            </h1>
            <p class="max-w-2xl text-[clamp(1.1rem,2vw,1.35rem)] leading-8 text-[var(--white-soft)]">
              {project.description}
            </p>
          </div>

          <div class="flex flex-wrap items-center gap-4 lg:justify-end border-t border-[var(--line)] pt-6 lg:border-none lg:pt-0">
            {project.link && (
              <Button href={project.link} target="_blank" rel="noopener noreferrer">
                Live Demo
              </Button>
            )}
            {project.github && (
              <Button href={project.github} variant="secondary" target="_blank" rel="noopener noreferrer">
                Source Code (GitHub)
              </Button>
            )}
          </div>
        </div>
      </div>
    </header>

    {/* Main Cover Image */}
    <div class="mx-auto w-[calc(100%_-_2rem)] max-w-[1440px] lg:w-[calc(100%_-_3rem)] mb-20 lg:mb-32">
      <figure class="relative overflow-hidden border border-[var(--line)] bg-[var(--surface-strong)] p-1 shadow-[0_32px_90px_var(--shadow-accent)]">
        <div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_0%,color-mix(in_srgb,var(--cyan)_15%,transparent),transparent_60%)]" aria-hidden="true"></div>
        <img
          class="relative w-full object-cover aspect-[16/9] lg:aspect-[21/9] border border-[var(--line)]"
          src={project.image}
          alt={`Screenshot of ${project.title}`}
        />
      </figure>
    </div>

    {/* Content Grid */}
    <div class="mx-auto w-[calc(100%_-_2rem)] max-w-[1440px] lg:w-[calc(100%_-_3rem)]">
      <div class="grid gap-16 lg:grid-cols-[300px_1fr] items-start">
        
        {/* Sticky Sidebar */}
        <aside class="lg:sticky lg:top-32 space-y-12">
          {project.role && (
            <div class="border-t border-[var(--line)] pt-8">
              <h3 class="mb-4 font-mono text-xs font-black uppercase tracking-[0.22em] text-[var(--orange)]">
                My Role
              </h3>
              <p class="text-sm font-extrabold uppercase tracking-widest text-[var(--text)]">
                {project.role}
              </p>
            </div>
          )}
          <div class="border-t border-[var(--line)] pt-8">
            <h3 class="mb-6 font-mono text-xs font-black uppercase tracking-[0.22em] text-[var(--cyan)]">
              Technologies Used
            </h3>
            <ul class="flex flex-col gap-3">
              {project.technologies.map((tech) => (
                <li class="inline-flex items-center gap-3 text-sm font-extrabold uppercase tracking-widest text-[var(--text)]">
                  <span class="h-1.5 w-1.5 rounded-full bg-[var(--orange)]" />
                  {tech}
                </li>
              ))}
            </ul>
          </div>
        </aside>

        {/* Main Details */}
        <div class="prose prose-invert max-w-none">
          
          {(project.challenge || project.solution) && (
            <div class="mb-24">
              <h2 class="text-[clamp(2rem,4vw,3rem)] font-black uppercase tracking-tight text-[var(--text)] mb-10 leading-none">
                Design & Architecture
              </h2>
              
              {project.challenge && (
                <div class="mb-12 relative overflow-hidden border border-[var(--line)] bg-[color-mix(in_srgb,var(--cyan)_3%,transparent)] p-8 lg:p-10">
                  <div class="absolute -right-10 -top-10 h-40 w-40 rounded-full bg-[var(--cyan)] blur-[80px] opacity-20"></div>
                  <h4 class="mb-4 font-mono text-xs font-black uppercase tracking-[0.2em] text-[var(--cyan)]">
                    The Challenge
                  </h4>
                  <p class="text-xl leading-relaxed text-[var(--text)] m-0 font-medium">
                    {project.challenge}
                  </p>
                </div>
              )}
              
              {project.solution && (
                <div>
                  <h4 class="mb-4 font-mono text-xs font-black uppercase tracking-[0.2em] text-[var(--orange)]">
                    The Solution
                  </h4>
                  <p class="text-lg leading-relaxed text-[var(--muted)]">
                    {project.solution}
                  </p>
                </div>
              )}
            </div>
          )}
        </div>
      </div>
    </div>

    {/* Full Width Gallery Band */}
    {project.gallery && project.gallery.length > 0 && (
      <div class="mt-32 w-full border-y border-[var(--line)] bg-[var(--surface)] py-16 overflow-hidden">
        <div class="mx-auto w-[calc(100%_-_2rem)] max-w-[1440px] lg:w-[calc(100%_-_3rem)] mb-12 flex justify-between items-end">
          <h2 class="text-[clamp(2rem,4vw,3rem)] font-black uppercase tracking-tight text-[var(--text)] leading-none">
            Visual Execution
          </h2>
          <div class="hidden md:flex gap-2">
            <button class="carousel-btn-prev h-10 w-10 rounded-full border border-[var(--line)] bg-[var(--panel)] flex items-center justify-center text-[var(--text)] hover:text-[var(--cyan)] hover:border-[var(--cyan)] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg>
            </button>
            <button class="carousel-btn-next h-10 w-10 rounded-full border border-[var(--line)] bg-[var(--panel)] flex items-center justify-center text-[var(--text)] hover:text-[var(--cyan)] hover:border-[var(--cyan)] transition-colors">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>
            </button>
          </div>
        </div>
        
        <div class="relative w-full">
          <div id="project-carousel" class="flex gap-6 overflow-x-auto snap-x snap-mandatory px-[calc(50vw_-_50%)] scroll-smooth hide-scrollbar pb-8 pt-4">
            {/* The px-[calc(...)] centering trick perfectly aligns the first item with the grid but allows full-width bleed */}
            <div class="w-[1rem] lg:w-[1.5rem] shrink-0"></div>
            {project.gallery.map((img, idx) => (
              <figure 
                class="group relative w-[85vw] md:w-[700px] aspect-[16/9] overflow-hidden rounded-xl border border-[var(--line)] bg-[var(--panel)] shrink-0 snap-center shadow-xl cursor-pointer"
                data-modal-img={img}
              >
                <div class="absolute inset-0 bg-[var(--cyan)] opacity-0 transition-opacity duration-500 group-hover:opacity-20 mix-blend-screen pointer-events-none z-10"></div>
                <div class="absolute inset-0 flex items-center justify-center opacity-0 transition-opacity duration-300 group-hover:opacity-100 z-20 pointer-events-none">
                  <span class="rounded-full bg-black/80 px-6 py-3 text-xs font-bold uppercase tracking-widest text-white backdrop-blur-md border border-white/20">
                    View Image
                  </span>
                </div>
                <img 
                  class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]" 
                  src={img} 
                  alt={`Gallery image ${idx + 1}`} 
                  loading="lazy" 
                  decoding="async" 
                />
              </figure>
            ))}
            <div class="w-[1rem] lg:w-[1.5rem] shrink-0"></div>
          </div>
        </div>
      </div>
    )}

  </article>

  {/* Image Modal */}
  <dialog id="imageModal" class="backdrop:bg-[var(--bg)] backdrop:opacity-95 bg-transparent p-0 m-auto w-full h-full border-none outline-none overflow-hidden open:animate-in open:fade-in">
    <div class="relative flex h-full w-full items-center justify-center p-4">
      <button id="closeModal" class="absolute top-6 right-6 text-[var(--muted)] hover:text-[var(--cyan)] transition-colors p-2 z-50 bg-[var(--panel)] border border-[var(--line)] rounded-full">
        <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
      <img id="modalImage" src="" alt="Full screen preview" class="max-w-full max-h-full object-contain rounded-xl shadow-2xl" />
    </div>
  </dialog>
</BaseLayout>

<script>
  // Modal Logic
  const figures = document.querySelectorAll('figure[data-modal-img]');
  const modal = document.getElementById('imageModal');
  const modalImg = document.getElementById('modalImage');
  const closeBtn = document.getElementById('closeModal');

  figures.forEach(fig => {
    fig.addEventListener('click', () => {
      const src = fig.getAttribute('data-modal-img');
      if (src && modal && modalImg) {
        modalImg.setAttribute('src', src);
        // @ts-ignore
        modal.showModal();
        document.body.style.overflow = 'hidden';
      }
    });
  });

  if (closeBtn && modal) {
    const closeModal = () => {
      // @ts-ignore
      modal.close();
      document.body.style.overflow = '';
    };
    closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', (e) => {
      if (e.target === modal) closeModal();
    });
  }

  // Carousel Buttons Logic
  const carousel = document.getElementById('project-carousel');
  const btnPrev = document.querySelector('.carousel-btn-prev');
  const btnNext = document.querySelector('.carousel-btn-next');

  if (carousel && btnPrev && btnNext) {
    const scrollAmount = window.innerWidth > 768 ? 700 + 24 : window.innerWidth * 0.85 + 24;
    
    btnPrev.addEventListener('click', () => {
      carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });
    
    btnNext.addEventListener('click', () => {
      carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });
  }
</script>

<style>
  /* Hide scrollbar for Chrome, Safari and Opera */
  .hide-scrollbar::-webkit-scrollbar {
    display: none;
  }
  /* Hide scrollbar for IE, Edge and Firefox */
  .hide-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
</style>
