---
import Layout from '../../layouts/Layout.astro';
import { ArrowLeft } from 'lucide-astro';
import Card from '../../components/ui/Card.astro';

export async function getStaticPaths() {
  const markdownFiles = import.meta.glob<Record<string, any>>('../../data/designs/*.md', { eager: true });
  const designs = Object.values(markdownFiles);
  
  return designs.map((design: any) => {
    // Extract filename without extension for the slug
    const slug = design.file.split('/').pop().replace('.md', '');
    return {
      params: { slug },
      props: { design },
    };
  });
}

interface Props {
  design: any;
}

const { design } = Astro.props;
const { Content, frontmatter } = design;
---

<Layout 
  title={`${frontmatter.title} | Gallery | AndrixNg1`}
  description={frontmatter.description}
  image={frontmatter.thumbnail}
>
  <section class="animate-fade-in">
    <Card className="relative overflow-hidden">
      <!-- Decorative Glow -->
      <div class="absolute top-0 right-0 -translate-y-1/2 translate-x-1/3 w-64 h-64 bg-accent-green/10 rounded-full blur-3xl pointer-events-none"></div>

      <a href="/gallery" class="inline-flex items-center gap-2 text-sm text-text-secondary hover:text-accent-green mb-8 transition-all duration-300 group bg-bg-secondary w-fit px-4 py-2 rounded-xl border border-border hover:border-accent-green">
        <ArrowLeft class="w-4 h-4 group-hover:-translate-x-1 transition-transform" /> Back to Gallery
      </a>
      
      <div class="mb-12 border-b border-border/50 pb-8">
        <h1 class="text-4xl md:text-5xl font-extrabold mb-4 text-transparent bg-clip-text bg-gradient-to-r from-white to-gray-400">{frontmatter.title}</h1>
        <p class="text-text-secondary text-lg md:text-xl max-w-3xl leading-relaxed">{frontmatter.description}</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 items-start">
        <!-- Markdown Content Left Side -->
        <div class="lg:col-span-4 lg:sticky lg:top-24">
          <div class="prose prose-invert prose-green max-w-none">
            <Content />
          </div>
        </div>

        <!-- Images Right Side -->
        <div class="lg:col-span-8 grid grid-cols-1 sm:grid-cols-2 gap-6">
          {frontmatter.images.map((img: string, index: number) => (
            <div class={`rounded-2xl overflow-hidden border border-border bg-bg-tertiary shadow-2xl group relative ${index === 0 || index % 3 === 0 ? 'sm:col-span-2' : ''}`}>
              <div class="absolute inset-0 bg-accent-green/20 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none mix-blend-overlay"></div>
              <img 
                src={img} 
                alt={`${frontmatter.title} - Preview ${index + 1}`}
                class="w-full h-auto object-cover group-hover:scale-[1.02] transition-transform duration-700 ease-out"
                loading={index === 0 ? "eager" : "lazy"}
              />
            </div>
          ))}
        </div>
      </div>
    </Card>
  </section>
</Layout>

<style is:global>
  .prose h2 {
    color: var(--text-primary);
    font-size: 1.5rem;
    font-weight: 700;
    margin-top: 2rem;
    margin-bottom: 1rem;
  }
  .prose h3 {
    color: var(--text-primary);
    font-size: 1.25rem;
    font-weight: 600;
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
  }
  .prose p {
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 1.25rem;
  }
  .prose ul {
    list-style-type: disc;
    padding-left: 1.5rem;
    margin-bottom: 1.25rem;
    color: var(--text-secondary);
  }
  .prose li {
    margin-bottom: 0.5rem;
  }
  .prose strong {
    color: var(--accent-green);
    font-weight: 600;
  }
  .animate-fade-in {
    animation: fadeIn 0.8s ease-out forwards;
  }
  @keyframes fadeIn {
    from { opacity: 0; transform: translateY(20px); }
    to { opacity: 1; transform: translateY(0); }
  }
</style>
